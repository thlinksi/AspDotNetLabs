@model Lab4.Models.ViewModels.ApplicationViewModel

<tr>
    <td>@Model.VacancyTitle</td>
    <td>@Model.Resume</td>
    <td>@Model.AppliedDate.ToShortDateString()</td>
    <td>
        <a asp-action="EditApplication" asp-controller="Vacancy" asp-route-id="@Model.ApplicationId" class="btn btn-sm btn-primary">Edit</a>
        <form asp-action="DeleteApplication" asp-controller="Vacancy" asp-route-id="@Model.ApplicationId" method="post" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this application?');">Delete</button>
        </form>
    </td>
</tr>