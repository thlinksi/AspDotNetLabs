@model Lab4.Models.Vacancy

<div class="row">
    <div class="col-12">
        <h2>Vacancy Details</h2>
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Title</dd>
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@Model.Description</dd>
            <dt class="col-sm-2">Company</dt>
            <dd class="col-sm-10">@Model.Company</dd>
            <dt class="col-sm-2">Salary</dt>
            <dd class="col-sm-10">@Model.Salary.ToString("N2") €</dd>
            <dt class="col-sm-2">Category</dt>
            <dd class="col-sm-10">@Model.Category</dd>
            <dt class="col-sm-2">Applications</dt>
            <dd class="col-sm-10">
                @if (Model.Applications != null && Model.Applications.Any())
                {
                    <ul>
                        @foreach (var app in Model.Applications)
                        {
                            <li>Application by @app.CandidateId on @app.AppliedDate.ToShortDateString()</li>
                        }
                    </ul>
                }
                else
                {
                    <p>No applications yet.</p>
                }
            </dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model.VacancyId" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.VacancyId" class="btn btn-danger">Delete</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>