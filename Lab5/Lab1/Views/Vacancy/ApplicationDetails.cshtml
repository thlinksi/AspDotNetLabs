@model Lab5.Models.Application

<div class="row">
    <div class="col-12">
        <h2>Application Details</h2>
        <dl class="row">
            <dt class="col-sm-2">Vacancy</dt>
            <dd class="col-sm-10">@(Model.Vacancy?.Title ?? "Vacancy Removed")</dd>
            <dt class="col-sm-2">Resume</dt>
            <dd class="col-sm-10">@Model.Resume</dd>
            <dt class="col-sm-2">Candidate ID</dt>
            <dd class="col-sm-10">@Model.CandidateId</dd>
            <dt class="col-sm-2">Applied Date</dt>
            <dd class="col-sm-10">@Model.AppliedDate.ToShortDateString()</dd>
        </dl>
        <a asp-action="EditApplication" asp-route-id="@Model.ApplicationId" class="btn btn-primary">Edit</a>
        <form asp-action="DeleteApplication" method="post" style="display:inline;">
            <input type="hidden" name="id" value="@Model.ApplicationId" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this application?');">Delete</button>
        </form>
        <a asp-action="MyApplications" class="btn btn-secondary">Back to List</a>
    </div>
</div>