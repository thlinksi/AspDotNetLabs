@model Lab5.Models.Vacancy

<div class="row">
    <div class="col-12">
        <h2>Delete Vacancy</h2>
        <h3>Are you sure you want to delete this vacancy?</h3>
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@Model.Title</dd>
            <dt class="col-sm-2">Company</dt>
            <dd class="col-sm-10">@Model.Company</dd>
            <dt class="col-sm-2">Category</dt>
            <dd class="col-sm-10">@Model.Category</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="VacancyId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>